{
  "info": {
    "name": "Food Delivery API",
    "description": "Complete Food Delivery REST API — Spring Boot\n\n## Quick Start\n1. Run the app: `mvn spring-boot:run`\n2. Login with any test account to get a token\n3. Set `{{token}}` variable from login response\n\n## Test Accounts\n- Admin: admin@fooddelivery.com / admin123\n- Customer: rahul@example.com / password123\n- Owner: owner@restaurant.com / owner123\n- Delivery: delivery@example.com / delivery123\n\n## Sample Coupons\n- WELCOME50 (50% off, max ₹200)\n- FLAT100 (₹100 off on orders ≥ ₹300)\n- FREEDEL (₹50 off delivery)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "food-delivery-api-v2"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token",   "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" }
  ],
  "event": [{
    "listen": "prerequest", "script": { "type": "text/javascript", "exec": [""] }
  }],
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/signup",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"test1234\",\n  \"phone\": \"9888888888\",\n  \"role\": \"CUSTOMER\"\n}" }
          }
        },
        {
          "name": "Login (Customer)",
          "event": [{ "listen": "test", "script": { "exec": [
            "var res = pm.response.json();",
            "if(res.data) {",
            "  pm.collectionVariables.set('token', res.data.accessToken);",
            "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
            "  console.log('Token saved');",
            "}"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/login",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"rahul@example.com\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [{ "listen": "test", "script": { "exec": [
            "var res = pm.response.json();",
            "if(res.data) {",
            "  pm.collectionVariables.set('token', res.data.accessToken);",
            "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
            "}"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/login",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@fooddelivery.com\",\n  \"password\": \"admin123\"\n}" }
          }
        },
        {
          "name": "Login (Owner)",
          "event": [{ "listen": "test", "script": { "exec": [
            "var res = pm.response.json();",
            "if(res.data) { pm.collectionVariables.set('token', res.data.accessToken); }"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/login",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"owner@restaurant.com\",\n  \"password\": \"owner123\"\n}" }
          }
        },
        {
          "name": "Login (Delivery Partner)",
          "event": [{ "listen": "test", "script": { "exec": [
            "var res = pm.response.json();",
            "if(res.data) { pm.collectionVariables.set('token', res.data.accessToken); }"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/login",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"delivery@example.com\",\n  \"password\": \"delivery123\"\n}" }
          }
        },
        {
          "name": "Refresh Token",
          "event": [{ "listen": "test", "script": { "exec": [
            "var res = pm.response.json();",
            "if(res.data) { pm.collectionVariables.set('token', res.data.accessToken); }"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/refresh",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/logout",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        }
      ]
    },
